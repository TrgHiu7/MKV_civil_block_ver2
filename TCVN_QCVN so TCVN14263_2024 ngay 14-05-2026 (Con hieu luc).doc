<p style="margin-top:6.0pt"><span lang="VI" style="font-size:
  10.0pt">&nbsp;</span></p>
</td>
<td style="width: 91.74%; background: transparent; padding: 0cm;" valign="bottom" width="91%">
<p style="margin-top:6.0pt"><span style="font-size:10.0pt">(3.5)
  <i>X</i> = invSubCells<i>(X)</i></span></p>
</td>
</tr>
<tr>
<td style="width: 8.26%; background: transparent; padding: 0cm;" valign="bottom" width="8%">
<p style="margin-top:6.0pt"><span lang="VI" style="font-size:
  10.0pt">&nbsp;</span></p>
</td>
<td style="width: 91.74%; background: transparent; padding: 0cm;" valign="bottom" width="91%">
<p style="margin-top:6.0pt"><span style="font-size:10.0pt">(3.6)
  <i>X = <img height="20" src="//files.thuvienphapluat.vn/doc2htm/00921576_files/image018.jpg" width="53"></i></span></p>
</td>
